# ── DATABASE ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mediavault
DB_USER=mediavault_user
DB_PASS=                       # contraseña de la base de datos
DB_SSL=false                   # true en producción con certificado

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                # dejar vacío si no se usa autenticación

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_de_minimo_64_caracteres_aleatorios_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_diferente_de_minimo_64_caracteres_aqui
JWT_REFRESH_EXPIRES_IN=8h

# ── WOWZA STREAMING ENGINE ────────────────────────────────────────────────────
WOWZA_HOST=localhost
WOWZA_PORT=8087
WOWZA_USER=admin
WOWZA_PASSWORD=wowza_password_seguro
WOWZA_STREAM_PORT=1935
WOWZA_SECURE_TOKEN_SECRET=secreto_minimo_32_caracteres_para_tokens

# ── STORAGE (evidencias forenses) ─────────────────────────────────────────────
STORAGE_PATH=./storage         # ruta absoluta recomendada en producción
MAX_UPLOAD_SIZE_MB=500

# ── CIFRADO (credenciales en BD) ──────────────────────────────────────────────
ENCRYPTION_KEY=genera_una_clave_hex_de_64_caracteres_con_openssl_rand_hex_32

# ── APLICACIÓN ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development           # development | production | test
FRONTEND_URL=http://localhost:5173

# ── TESTS E2E (base de datos separada) ───────────────────────────────────────
DB_TEST_NAME=mediavault_test
